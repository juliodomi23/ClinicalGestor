# ─── Variables de entorno para producción (EasyPanel) ───────────────────────
# Copia este archivo como .env y rellena los valores antes de desplegar.

# ── Conexión MongoDB ─────────────────────────────────────────────────────────
MONGO_URL=mongodb://dentu_mongo:27017
DB_NAME=dentu_db

# ── CORS (URL pública del frontend, sin barra al final) ──────────────────────
CORS_ORIGINS=https://tu-dominio-frontend.com

# ── Seguridad — genera valores únicos y secretos para cada despliegue ────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia-esto-por-un-secreto-seguro-32chars
WEBHOOK_API_KEY=cambia-esto-por-tu-api-key-para-n8n

# ── Admin inicial (se crea solo si la BD está vacía al arrancar) ─────────────
# Después del primer arranque puedes eliminar estas variables si quieres
FIRST_ADMIN_EMAIL=admin@tuclinica.com
FIRST_ADMIN_PASSWORD=CambiaMeAhora1
FIRST_ADMIN_NAME=Administrador

# ── Identidad de la clínica (white-label) ────────────────────────────────────
CLINIC_NAME=Clínica Dental Ejemplo
CLINIC_LOGO_URL=https://tu-dominio.com/logo.png
CLINIC_PRIMARY_COLOR=#0ea5e9
CLINIC_PHONE=+52 555 123 4567
CLINIC_ADDRESS=Av. Principal 123, Ciudad
CLINIC_TIMEZONE=America/Mexico_City

# ── Horario laboral ───────────────────────────────────────────────────────────
WORK_START=8        # hora de inicio (formato 24h, entero)
WORK_END=19         # hora de fin exclusivo (el último slot termina antes de esta hora)
SLOT_DURATION=30    # duración de cada slot en minutos
APPOINTMENT_PRICE=150.0  # precio base por cita para cálculo de ingresos del dashboard

# ── Google Sign-In + Drive centralizado (opcional) ───────────────────────────
# Client ID de OAuth 2.0 (Google Cloud Console → Credenciales)
GOOGLE_CLIENT_ID=

# Credenciales de la cuenta de servicio.
# Opción A — ruta al archivo JSON descargado de Google Cloud:
#   GOOGLE_SERVICE_ACCOUNT_JSON=/ruta/a/service-account.json
# Opción B — contenido JSON completo en una sola línea (para EasyPanel/Docker):
#   GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":...}
GOOGLE_SERVICE_ACCOUNT_JSON=

# ID de la carpeta de Google Drive de la clínica donde se guardarán los archivos.
# Pasos: 1) Crea una carpeta en el Drive de la clínica, 2) Compártela con el
# email de la cuenta de servicio (con rol "Editor"), 3) Copia el ID de la URL.
GOOGLE_DRIVE_FOLDER_ID=
