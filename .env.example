# ── Copia este archivo como .env y rellena los valores ───────────────────────
# No subas el .env al repositorio — solo el .env.example

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=cambia-esto-por-una-password-segura
MONGO_DB=clinicalgestor

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=cambia-esto-por-un-secreto-de-32-chars
WEBHOOK_API_KEY=cambia-esto-por-tu-api-key-para-n8n

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL pública del frontend (sin barra al final)
FRONTEND_URL=https://tu-dominio.com
# URL pública del backend (para que el frontend sepa dónde conectarse)
BACKEND_URL=https://api.tu-dominio.com

# ── Admin inicial (solo se crea si la BD está vacía) ─────────────────────────
FIRST_ADMIN_EMAIL=admin@tuclinica.com
FIRST_ADMIN_PASSWORD=CambiaMeAhora1
FIRST_ADMIN_NAME=Administrador

# ── Identidad de la clínica ───────────────────────────────────────────────────
CLINIC_NAME=Mi Clínica Dental
CLINIC_LOGO_URL=https://tu-dominio.com/logo.png
CLINIC_PRIMARY_COLOR=#0ea5e9
CLINIC_TIMEZONE=America/Mexico_City

# ── Horario laboral ───────────────────────────────────────────────────────────
WORK_START=8
WORK_END=19
SLOT_DURATION=30
APPOINTMENT_PRICE=150
